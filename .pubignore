# The yse-soundengine submodule contains the C++ source tree (~9 MB)
# and is only consumed at build time. v0.x consumers point YSE_DLL_PATH
# at a locally-built libyse.dll per the README; the native-assets build
# hook (which will publish-time pull pre-built DLLs) lands in a later
# release.
third_party/

# Local Claude IDE config — never publish.
.claude/
YSElog.txt

# Sibling Flutter plugin and its Android sample app are published as a
# separate package (yse_flutter_libs) and a non-publishable sample; they
# don't belong inside the yse package tarball.
packages/
example/android_sample/

# Docs site sources and generated outputs — pub.dev renders dartdoc, so
# the Sphinx site is only useful from the GitHub Pages deployment.
docs/
